# Ollama model settings
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDINGS_MODEL=llama3
OLLAMA_TEMPERATURE=0
OLLAMA_NUM_PREDICT=256

# Text splitting
TEXT_SPLITTER_CHUNK_SIZE=500
TEXT_SPLITTER_CHUNK_OVERLAP=50

# Storage
DOCUMENTS_DIR=documents/uploads

# MongoDB (local Compass)
MONGODB_URI=mongodb://localhost:27017/?appName=Agentic_Project
MONGODB_DB_NAME=agentic_research
MONGODB_UPLOADS_COLLECTION=uploads
MONGODB_CHUNKS_COLLECTION=chunks
MONGODB_JOBS_COLLECTION=job
MONGODB_MESSAGES_COLLECTION=messages

# Agent routing / retrieval
ENABLE_WEB_SEARCH=0
RETRIEVER_K_DENSE=2
RETRIEVER_K_SPARSE=4
MAX_CHUNK_CHARS=1200
MAX_TOTAL_CONTEXT_CHARS=4000
MEMORY_MAX_MESSAGES=12

# Local persistence (survive server restarts)
FAISS_PERSIST_DIR=vectorstore_data/faiss
BOOTSTRAP_SPARSE_FROM_MONGO=1
BOOTSTRAP_DENSE_FROM_DISK=1
